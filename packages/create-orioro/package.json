{
  "name": "create-orioro",
  "version": "0.0.0",
  "packageManager": "yarn@4.0.2",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": "./dist/cli.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "rm -rf dist && rollup --config ./rollup.config.mjs && chmod +x dist/cli.mjs",
    "test": "jest",
    "readme": "readme",
    "dev:run": "yarn build && node dist/cli.mjs"
  },
  "devDependencies": {
    "@orioro/dev": "workspace:^",
    "@orioro/readme": "^1.0.1",
    "@types/jest": "^29.5.12",
    "babel-jest": "^30.3.0",
    "jest": "^29.7.0",
    "rollup": "^4.13.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "degit": "^2.8.4"
  }
}
