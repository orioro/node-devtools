{
  "name": "@orioro/dev",
  "packageManager": "yarn@4.0.2",
  "version": "0.0.6",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "rollup --config ./rollup.config.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.cjs"
    },
    "./ts": {
      "import": "./dist/ts/index.mjs",
      "require": "./dist/ts/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/nextjs": "^8.0.0",
    "@storybook/test": "^8.0.0",
    "rollup": "^4.13.0",
    "rollup-plugin-import-css": "^3.5.0",
    "storybook": "^8.0.0",
    "typescript": "^5.3.3",
    "webpack": "5.101.2"
  },
  "_comments": [
    "webpack must be pinned to 5.101.2 for storybook compat. see: https://github.com/storybookjs/storybook/issues/32301 AND https://github.com/storybookjs/storybook/pull/32306"
  ]
}
