{
  "name": "@orioro/template-react",
  "private": true,
  "version": "0.0.3",
  "packageManager": "yarn@4.0.2",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.mjs",
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "private"
  },
  "license": "ISC",
  "scripts": {
    "prepublish": "npm run build",
    "build": "rm -rf dist && rollup --config ./rollup.config.mjs",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@orioro/dev": "workspace:^",
    "@types/react": "^18.2.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "rollup": "^4.13.0",
    "storybook": "^8.0.0",
    "styled-components": "^6.1.8"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.8"
  }
